/* Qt Style Sheet generated by flair */

QWidget {
  background-color: #1a1b26;
  color: #c0caf5;
}

QMainWindow {
  background-color: #1a1b26;
  color: #c0caf5;
}

QPushButton {
  background-color: #1f2335;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QLineEdit {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QTextEdit {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QPlainTextEdit {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QComboBox {
  background-color: #1f2335;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QMenuBar {
  background-color: #16161e;
  color: #c0caf5;
}

QMenu {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QMenu::item:selected {
  background-color: #292e42;
  color: #c0caf5;
}

QToolBar {
  background-color: #16161e;
  color: #c0caf5;
  border: none;
}

QStatusBar {
  background-color: #16161e;
  color: #a9b1d6;
}

QTabWidget::pane {
  background-color: #1a1b26;
  border: 1px solid #ff9e64;
}

QTabBar::tab {
  background-color: #1f2335;
  color: #a9b1d6;
  border: 1px solid #ff9e64;
}

QTabBar::tab:selected {
  background-color: #1a1b26;
  color: #c0caf5;
  border-bottom: 2px solid #7aa2f7;
}

QCheckBox {
  color: #c0caf5;
}

QRadioButton {
  color: #c0caf5;
}

QGroupBox {
  border: 1px solid #ff9e64;
  color: #c0caf5;
}

QScrollBar {
  background-color: #1f2335;
}

QScrollBar::handle {
  background-color: #32364e;
}

QToolTip {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QProgressBar {
  background-color: #1f2335;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QProgressBar::chunk {
  background-color: #7aa2f7;
}

QDockWidget {
  background-color: #16161e;
  color: #a9b1d6;
}

QHeaderView::section {
  background-color: #1f2335;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QTreeView {
  background-color: #16161e;
  color: #c0caf5;
}

QListView {
  background-color: #16161e;
  color: #c0caf5;
}

QTableView {
  background-color: #16161e;
  color: #c0caf5;
}

QTreeView::item:selected {
  background-color: #7aa2f7;
  color: #1a1b26;
}

QSpinBox {
  background-color: #16161e;
  color: #c0caf5;
  border: 1px solid #ff9e64;
}

QSlider::groove {
  background-color: #1f2335;
}

QSlider::handle {
  background-color: #7aa2f7;
}

QLabel {
  color: #c0caf5;
}

QLineEdit:focus {
  border: 1px solid #5d7ab8;
}

QTextEdit:focus {
  border: 1px solid #5d7ab8;
}

QPushButton:hover {
  background-color: #292e42;
  color: #c0caf5;
}

QPushButton:pressed {
  background-color: #2d3650;
  color: #c0caf5;
}

QComboBox:hover {
  background-color: #292e42;
}

QTabBar::tab:hover {
  background-color: #292e42;
}

QCheckBox::indicator:checked {
  background-color: #7aa2f7;
  color: #1a1b26;
}

QRadioButton::indicator:checked {
  background-color: #7aa2f7;
  color: #1a1b26;
}
